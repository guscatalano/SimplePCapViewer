<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="PcapViewer.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:PcapViewer.Core.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

        <!-- ===== Toolbar ===== -->
        <Grid Grid.Row="0" Padding="12,8" ColumnSpacing="10"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1"
              ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto">

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                <Button Click="OnOpenClick" Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8E5;" FontSize="14" />
                        <TextBlock Text="Open capture" />
                    </StackPanel>
                </Button>
                <Button Click="OnTlsKeysClick"
                        ToolTipService.ToolTip="Load a TLS key log file (SSLKEYLOGFILE) to decrypt HTTPS">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE72E;" FontSize="14" />
                        <TextBlock x:Name="TlsButtonLabel" Text="TLS keys" />
                    </StackPanel>
                </Button>
                <Button Click="OnAttachClick"
                        ToolTipService.ToolTip="Attach a Windows Event Log (.evtx) or ETW trace (.etl) for correlation">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE723;" FontSize="14" />
                        <TextBlock x:Name="AttachButtonLabel" Text="Attach&#x2026;" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <TextBlock Grid.Column="1" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                       Style="{StaticResource BodyStrongTextBlockStyle}"
                       Text="{x:Bind ViewModel.FileName, Mode=OneWay}" />

            <ProgressRing Grid.Column="2" Width="20" Height="20"
                          IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />

            <HyperlinkButton Grid.Column="3" VerticalAlignment="Center" Padding="4,0"
                             Click="OnMcpStatusClick"
                             ToolTipService.ToolTip="Click for client configuration (URL + Claude Code / Claude Desktop / VS Code snippets)"
                             Content="{x:Bind ViewModel.McpStatus, Mode=OneWay}" />

            <TextBox Grid.Column="4" Width="74" PlaceholderText="Port"
                     VerticalAlignment="Center" ToolTipService.ToolTip="MCP server port"
                     Text="{x:Bind ViewModel.PortText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Grid.Column="5" Text="MCP server" VerticalAlignment="Center" />

            <ToggleSwitch Grid.Column="6" MinWidth="0" Toggled="OnMcpToggled" VerticalAlignment="Center" />
        </Grid>

        <!-- ===== Search bar ===== -->
        <Grid Grid.Row="1" Padding="12,8" ColumnSpacing="8"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1"
              ColumnDefinitions="Auto,220,Auto,*,Auto,Auto,Auto">

            <FontIcon Grid.Column="0" Glyph="&#xE721;" FontSize="14" VerticalAlignment="Center"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

            <TextBox Grid.Column="1" PlaceholderText="Quick find (instant)"
                     TextChanged="OnQuickSearchTextChanged" VerticalAlignment="Center" />

            <TextBlock Grid.Column="2" Text="Display filter" VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

            <TextBox Grid.Column="3" VerticalAlignment="Center" FontFamily="Consolas"
                     PlaceholderText="Wireshark display filter, e.g.  http.request || tcp.port == 443"
                     Text="{x:Bind ViewModel.DisplayFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     KeyDown="OnDisplayFilterKeyDown" />

            <Button Grid.Column="4" Content="Apply" Command="{x:Bind ViewModel.ApplyFilterCommand}" />
            <Button Grid.Column="5" Content="Clear" Command="{x:Bind ViewModel.ClearFilterCommand}" />

            <TextBlock Grid.Column="6" VerticalAlignment="Center" MinWidth="150" TextAlignment="Right"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="{x:Bind ViewModel.ResultInfo, Mode=OneWay}" />
        </Grid>

        <!-- ===== Main area ===== -->
        <Grid Grid.Row="2" RowDefinitions="3*,2*">

            <!-- Packet list -->
            <Grid Grid.Row="0" RowDefinitions="Auto,*">
                <Grid Grid.Row="0" Padding="12,6"
                      Background="{ThemeResource LayerFillColorDefaultBrush}"
                      BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1"
                      ColumnDefinitions="66,110,160,160,90,70,*">
                    <TextBlock Grid.Column="0" Text="No." Style="{StaticResource CaptionTextBlockStyle}" TextAlignment="Right" Margin="0,0,12,0" />
                    <TextBlock Grid.Column="1" Text="Time" Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBlock Grid.Column="2" Text="Source" Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBlock Grid.Column="3" Text="Destination" Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBlock Grid.Column="4" Text="Protocol" Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBlock Grid.Column="5" Text="Length" Style="{StaticResource CaptionTextBlockStyle}" TextAlignment="Right" Margin="0,0,12,0" />
                    <TextBlock Grid.Column="6" Text="Info" Style="{StaticResource CaptionTextBlockStyle}" />
                </Grid>

                <ListView Grid.Row="1"
                          ItemsSource="{x:Bind ViewModel.Packets, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedPacket, Mode=TwoWay}"
                          SelectionChanged="OnPacketSelectionChanged"
                          SelectionMode="Single"
                          ScrollViewer.HorizontalScrollMode="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="MinHeight" Value="0" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:PacketSummary">
                            <Grid Padding="12,3" ColumnDefinitions="66,110,160,160,90,70,*">
                                <Grid.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Copy row" Click="OnCopyPacketRow" />
                                        <MenuFlyoutSeparator />
                                        <MenuFlyoutItem Text="Copy source" Click="OnCopyPacketSource" />
                                        <MenuFlyoutItem Text="Copy destination" Click="OnCopyPacketDestination" />
                                        <MenuFlyoutItem Text="Copy protocol" Click="OnCopyPacketProtocol" />
                                        <MenuFlyoutItem Text="Copy info" Click="OnCopyPacketInfo" />
                                    </MenuFlyout>
                                </Grid.ContextFlyout>
                                <TextBlock Grid.Column="0" Text="{x:Bind Number}" TextAlignment="Right" Margin="0,0,12,0"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Grid.Column="1" Text="{x:Bind TimeDisplay}" FontFamily="Consolas" />
                                <TextBlock Grid.Column="2" Text="{x:Bind Source}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="3" Text="{x:Bind Destination}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="4" Text="{x:Bind Protocol}" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="5" Text="{x:Bind Length}" TextAlignment="Right" Margin="0,0,12,0" />
                                <TextBlock Grid.Column="6" Text="{x:Bind Info}" TextTrimming="CharacterEllipsis"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- Packet detail -->
            <Grid Grid.Row="1" RowDefinitions="Auto,*"
                  BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
                <Grid Grid.Row="0" ColumnDefinitions="3*,2*"
                      Background="{ThemeResource LayerFillColorDefaultBrush}">
                    <TextBlock Grid.Column="0" Padding="12,6" Text="{x:Bind ViewModel.DetailStatus, Mode=OneWay}"
                               Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBlock Grid.Column="1" Padding="12,6" Text="Frame bytes"
                               Style="{StaticResource CaptionTextBlockStyle}" />
                </Grid>

                <Grid Grid.Row="1" ColumnDefinitions="3*,2*">
                    <TreeView Grid.Column="0" x:Name="DetailTree" SelectionMode="None"
                              CanDragItems="False" CanReorderItems="False" AllowDrop="False">
                        <TreeView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Content}" FontSize="12"
                                           TextWrapping="NoWrap" Padding="0,2">
                                    <TextBlock.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem Text="Copy" Click="OnCopyDetailSubtree" />
                                            <MenuFlyoutItem Text="Copy line only" Click="OnCopyDetailLine" />
                                        </MenuFlyout>
                                    </TextBlock.ContextFlyout>
                                </TextBlock>
                            </DataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>

                    <ScrollViewer Grid.Column="1" HorizontalScrollMode="Auto" HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1,0,0,0">
                        <TextBlock Text="{x:Bind ViewModel.HexDump, Mode=OneWay}" FontFamily="Consolas"
                                   FontSize="12" Padding="12,8" IsTextSelectionEnabled="True" />
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>

        <!-- ===== Status bar ===== -->
        <Border Grid.Row="3" Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
            <TextBlock Padding="12,5" Style="{StaticResource CaptionTextBlockStyle}"
                       Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" />
        </Border>
    </Grid>
</Window>
