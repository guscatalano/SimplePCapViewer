<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="PcapViewer.App.AttachInstructionsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Attach event log or ETW trace"
    PrimaryButtonText="Browse for .etl or .evtx…"
    CloseButtonText="Cancel"
    DefaultButton="Primary">

    <ContentDialog.Resources>
        <!-- Override the default ContentDialog width so the long capture commands fit without wrapping. -->
        <x:Double x:Key="ContentDialogMinWidth">780</x:Double>
        <x:Double x:Key="ContentDialogMaxWidth">880</x:Double>
    </ContentDialog.Resources>

    <ScrollViewer MaxHeight="600" VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled">
        <StackPanel Spacing="14" MinWidth="720" Padding="0,0,14,0">

            <TextBlock TextWrapping="Wrap"
                Text="Attach a Windows .evtx or .etl file alongside the pcap for OS-side context — DNS lookups, TLS handshake errors, Wi-Fi events, firewall verdicts, PID-per-socket. Pick a capture command below, run it in an Administrator command prompt, then click Browse." />

            <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}"
                       Text="ETW trace — packets + TCPIP / Winsock-AFD / DNS / Schannel" />
            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="Produces trace.etl in the current directory. Run as Administrator." />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox Grid.Column="0" x:Name="NetshBox" IsReadOnly="True" FontFamily="Consolas"
                         AcceptsReturn="True" TextWrapping="NoWrap" MinHeight="64"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                <Button Grid.Column="1" Click="OnCopyNetsh" Content="Copy" VerticalAlignment="Top" />
            </Grid>

            <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}"
                       Text="Targeted ETW — only the providers you want" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox Grid.Column="0" x:Name="LogmanBox" IsReadOnly="True" FontFamily="Consolas"
                         AcceptsReturn="True" TextWrapping="NoWrap" MinHeight="100"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                <Button Grid.Column="1" Click="OnCopyLogman" Content="Copy" VerticalAlignment="Top" />
            </Grid>

            <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}"
                       Text="Schannel TLS errors from the System event log" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox Grid.Column="0" x:Name="SchannelBox" IsReadOnly="True" FontFamily="Consolas"
                         TextWrapping="NoWrap" ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                <Button Grid.Column="1" Click="OnCopySchannel" Content="Copy" />
            </Grid>

            <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}"
                       Text="DNS lookups (Microsoft-Windows-DNS-Client/Operational)" />
            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="The channel is off by default; the first command enables it." />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox Grid.Column="0" x:Name="DnsBox" IsReadOnly="True" FontFamily="Consolas"
                         AcceptsReturn="True" TextWrapping="NoWrap" MinHeight="48"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                <Button Grid.Column="1" Click="OnCopyDns" Content="Copy" VerticalAlignment="Top" />
            </Grid>

            <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}"
                       Text="Wi-Fi associate / disconnect / roam" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox Grid.Column="0" x:Name="WlanBox" IsReadOnly="True" FontFamily="Consolas"
                         TextWrapping="NoWrap" ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                <Button Grid.Column="1" Click="OnCopyWlan" Content="Copy" />
            </Grid>

            <HyperlinkButton Click="OnOpenReadme" Content="Full list and providers in the README" />
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
