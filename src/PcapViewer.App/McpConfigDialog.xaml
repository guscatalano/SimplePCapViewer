<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="PcapViewer.App.McpConfigDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="MCP server is running"
    CloseButtonText="Close"
    DefaultButton="Close">

    <ScrollViewer MaxHeight="560" HorizontalScrollMode="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="14" MinWidth="560">

            <TextBlock TextWrapping="Wrap"
                       Text="An MCP client connects to the URL below over streamable HTTP. Pick the snippet for your client and paste it." />

            <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="Server URL" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox Grid.Column="0" x:Name="UrlBox" IsReadOnly="True" FontFamily="Consolas" />
                <Button Grid.Column="1" Click="OnCopyUrl" Content="Copy" />
            </Grid>

            <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="Claude Code (CLI)" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox Grid.Column="0" x:Name="ClaudeCodeBox" IsReadOnly="True" FontFamily="Consolas" TextWrapping="Wrap" />
                <Button Grid.Column="1" Click="OnCopyClaudeCode" Content="Copy" VerticalAlignment="Top" />
            </Grid>

            <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="Claude Desktop  —  claude_desktop_config.json" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox Grid.Column="0" x:Name="ClaudeDesktopBox" IsReadOnly="True" FontFamily="Consolas"
                         AcceptsReturn="True" TextWrapping="NoWrap" MinHeight="120"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                <Button Grid.Column="1" Click="OnCopyClaudeDesktop" Content="Copy" VerticalAlignment="Top" />
            </Grid>

            <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="VS Code  —  .vscode/mcp.json" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox Grid.Column="0" x:Name="VsCodeBox" IsReadOnly="True" FontFamily="Consolas"
                         AcceptsReturn="True" TextWrapping="NoWrap" MinHeight="120"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                <Button Grid.Column="1" Click="OnCopyVsCode" Content="Copy" VerticalAlignment="Top" />
            </Grid>

            <HyperlinkButton Click="OnOpenBrowser" Content="Open the setup page in a browser" />
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
