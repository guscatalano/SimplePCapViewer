<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="SimplePCapViewer"
           Manufacturer="Gus Catalano"
           Version="$(var.AppVersion)"
           UpgradeCode="d25429c3-550a-4d41-a0c6-60632ace4435"
           Scope="perMachine">

    <MediaTemplate EmbedCab="yes" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />

    <Icon Id="AppIcon" SourceFile="src\PcapViewer.App\Assets\AppIcon.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="SimplePCapViewer" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppShortcutFolder" Name="SimplePCapViewer" />
    </StandardDirectory>

    <!-- All files from `dotnet publish` (self-contained app). -->
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Files Include="publish\**" />
    </ComponentGroup>

    <Component Id="AppShortcut" Directory="AppShortcutFolder"
               Guid="2a994c57-bd87-4119-9a2a-a92e3a523ca3">
      <Shortcut Id="StartMenuShortcut"
                Name="SimplePCapViewer"
                Description="Searchable pcap/pcapng viewer with an embedded MCP server"
                Target="[INSTALLFOLDER]SimplePCapViewer.exe"
                WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="RemoveAppShortcutFolder" On="uninstall" />
      <RegistryValue Root="HKCU" Key="Software\GusCatalano\SimplePCapViewer"
                     Name="installed" Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <Feature Id="MainApp" Title="SimplePCapViewer" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentRef Id="AppShortcut" />
    </Feature>
  </Package>
</Wix>
